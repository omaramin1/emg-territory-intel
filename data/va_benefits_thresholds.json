  "key_findings": {
    "multiple_income_tests": "SNAP requires both gross AND net income limits to be met for most households",
    "categorical_eligibility": "Virginia SNAP uses BBCE allowing some households to qualify with income up to 200% FPL",
    "magi_usage": "Virginia Medicaid uses MAGI (Modified Adjusted Gross Income) methodology, not regular gross income",
    "ami_variation": "Section 8 income limits vary significantly by geographic area (50% AMI used for qualification)",
    "asset_limits": "SSI asset limits ($2,000 single/$3,000 married) have not been updated for inflation in many years",
    "lifeline_alternative": "Can qualify for Lifeline automatically if receiving SNAP, Medicaid, SSI, Fed Housing Assistance, or Veterans Benefits",
    "school_lunch_calculation": "2025 FPL multiplied by 130% (free) or 185% (reduced) and rounded up",
    "medicare_savings_state_variation": "Virginia uses specific asset limits slightly different from federal defaults in some cases"
